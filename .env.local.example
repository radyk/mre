# .env.local.example — copy to `.env.local` (repo root) and fill in.
#
# `.env.local` is GITIGNORED (see .gitignore) and never committed — CI's gitleaks
# scan guards against an accidental key commit. `src/cockpit/dev_api.ps1` loads
# this file into the API server's process environment on startup (KEY=VALUE per
# line; '#' comments and blank lines ignored; surrounding quotes stripped; an
# already-set environment variable is never overwritten). So a key placed here
# reaches the M10 LLM renderer with NO terminal typing.
#
#   cp .env.local.example .env.local     # then edit .env.local
#   ./src/cockpit/dev_api.ps1            # loads .env.local, starts the API
#
# This example file carries NO real secret — it is safe to commit.

# The Anthropic API key for the DEV cockpit's fail-closed LLM renderer. With no
# key set the server drops back to the deterministic template renderer, silently
# and correctly (there is no path from a missing key to an error or to
# unvalidated prose). NEVER put a real key in a committed file.
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Optional overrides (dev_api.ps1 sets sensible defaults if these are absent):
#   MRE_DEV=1          # gates the dev-only surfaces (LLM wiring, /ledger/refusals)
#   MRE_DATA_ROOT=./_data
