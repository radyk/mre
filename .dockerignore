# Keep the build context small and reproducible. Runtime artifacts, caches,
# and the developer-local (gitignored) extracts never belong in an image.
.git
.gitignore
**/__pycache__
**/*.pyc
.pytest_cache
*.egg-info
.venv
venv

# Runtime / evidence output (regenerated; never source)
evidence_store/
snapshots/
runs/
mre_output/
mre_demo_output/
mre_output_whatif/
mre_api_data/
runs/

# Developer-local extracts (gitignored) and their profile
raw_data/
raw_data_profile.md

# Legacy and deploy scaffolding are not needed to build/run the service image.
# docs/ IS in the context: spec-derived tests read the spec text (e.g.
# test_remediation_catalog lints the catalog against docs/06). Only the test
# stage COPYs docs/ + datasets/ — the shipped runtime stage copies neither, so
# it stays lean (session 2.4b, first real container build).
legacy/
deploy/
*.md
!README.md

# Generated gate output inside committed datasets is never source (mirrors
# .gitignore); keep it out of the test image so a stale run never ships.
datasets/**/gate_output/
