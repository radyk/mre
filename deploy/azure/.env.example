# Copy to deploy/azure/.env (git-ignored) and fill in. Secrets stay OUT of the
# repo and the image — they are injected at deploy time (docs/08 §3).

# Required
RESOURCE_GROUP=mre-pilot-rg
ACR_NAME=mrepilotacr          # ACR name without .azurecr.io

# Optional (defaults shown)
LOCATION=eastus
NAME=mre
# IMAGE_TAG defaults to the current git short SHA.
# IMAGE_TAG=latest

# Optional secret — the M10 explainer LLM path. Leave unset to run without it.
# ANTHROPIC_API_KEY=sk-ant-...
